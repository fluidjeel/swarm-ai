# Copy to .env (gitignored). Never commit real keys.
# Generate .env locally with: python scripts/setup_local_env.py

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
DEEPSEEK_API_KEY=

# Default eval provider: openai | anthropic | grok | deepseek
EVAL_LLM_PROVIDER=openai
EVAL_LLM_MODEL=

# AWS SSM Parameter Store (EC2/production)
A2A_SECRETS_SOURCE=auto
A2A_SSM_PARAM_PREFIX=/a2a/llm
AWS_REGION=ap-south-1
