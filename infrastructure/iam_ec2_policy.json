{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBPutTraceOnly",
      "Effect": "Allow",
      "Action": ["dynamodb:PutItem"],
      "Resource": "arn:aws:dynamodb:ap-south-1:YOUR_AWS_ACCOUNT_ID:table/A2A_Traces"
    },
    {
      "Sid": "S3ReadPromptsOnly",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::a2a-prompts/*"
    },
    {
      "Sid": "SSMReadLLMKeys",
      "Effect": "Allow",
      "Action": ["ssm:GetParameter", "ssm:GetParameters"],
      "Resource": "arn:aws:ssm:ap-south-1:YOUR_AWS_ACCOUNT_ID:parameter/a2a/llm/*"
    },
    {
      "Sid": "KMSDecryptSSMDefaults",
      "Effect": "Allow",
      "Action": ["kms:Decrypt"],
      "Resource": "arn:aws:kms:ap-south-1:YOUR_AWS_ACCOUNT_ID:key/*",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "ssm.ap-south-1.amazonaws.com"
        }
      }
    }
  ]
}
